# Always generate package-lock.json for reproducible installs
package-lock=true

# Pin exact versions — no ^ or ~ drift
save-exact=true

# Fail if audit finds high/critical CVEs during install
audit-level=high

# Never run install scripts from dependencies
ignore-scripts=false
# ^ set to true only in CI via `npm ci --ignore-scripts`
# (kept false locally so devtools like husky can install hooks)

# Enforce provenance on publish
provenance=true
